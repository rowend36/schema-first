{
  "name": "@schema-first/core",
  "version": "0.3.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "Contributing.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts --external react",
    "lint": "tsc && eslint src/",
    "check": "tsc --noEmit",
    "release": "npm run lint && npm run build && changeset publish",
    "version": "changeset version && npm install"
  },
  "description": "A comprehensive spec framework for describing resources used by frontends as a foundation for meta-driven UIs.",
  "keywords": [
    "spec",
    "meta",
    "framework"
  ],
  "homepage": "https://github.com/rowend36/schema-first#readme",
  "bugs": {
    "url": "https://github.com/rowend36/schema-first/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rowend36/schema-first.git"
  },
  "license": "Apache-2.0",
  "author": "rowend36",
  "directories": {
    "test": "test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "globals": "^15.0.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "@types/react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  }
}
